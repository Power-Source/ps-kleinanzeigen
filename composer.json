{
  "name": "ps-kleinanzeigen/ps-kleinanzeigen",
  "description": "Classifieds plugin for WordPress",
  "type": "wordpress-plugin",
  "license": "GPL-2.0-or-later",
  "authors": [
    {
      "name": "PS Kleinanzeigen",
      "role": "Developer"
    }
  ],
  "require": {
    "php": ">=7.4"
  },
  "require-dev": {
    "phpstan/phpstan": "^1.10",
    "phpstan/phpstan-strict-rules": "^1.5",
    "szepeviktor/phpstan-wordpress": "^1.3"
  },
  "config": {
    "allow-plugins": {
      "composer/installers": true
    }
  },
  "suggest": {
    "phpstan/phpstan": "For static analysis and code quality checks"
  }
}
